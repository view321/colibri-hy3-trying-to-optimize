def python_for_tools():
    """Pick Python for offline tools (convert, bench). Needs numpy + torch + safetensors."""
    override = os.environ.get("COLI_PYTHON")
    if override and os.path.isfile(override):
        return override
    mio = os.path.join(HERE, "mio_env", "Scripts" if sys.platform == "win32" else "bin", "python3")
    if os.path.isfile(mio):
        return mio
    bindir = "Scripts" if sys.platform == "win32" else "bin"
    for envkey in ("CONDA_PREFIX", "VIRTUAL_ENV"):
        base = os.environ.get(envkey)
        if not base:
            continue
        for name in ("python", "python3"):
            cand = os.path.join(base, bindir, name)
            if os.path.isfile(cand):
                return cand
    for cand in (sys.executable, shutil.which("python"), shutil.which("python3")):
        if not cand or not os.path.isfile(cand):
            continue
        try:
            subprocess.run([cand, "-c", "import numpy"], capture_output=True, check=True, timeout=15)
            return cand
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired, OSError):
            continue
    return sys.executable

def model_config(model):
    path=os.path.join(model,"config.json")
    if not os.path.isfile(path): return {}
    try: return json.load(open(path,encoding="utf-8"))
    except (OSError,json.JSONDecodeError): return {}

def engine_for(model):
    forced=os.environ.get("COLI_ENGINE","").lower()
    if forced in ("hy3","glm"): return HY3 if forced=="hy3" else GLM
    cfg=model_config(model)
    return HY3 if cfg.get("model_type")=="hy_v3" else GLM

def engine_name(model):
    return "hy3" if engine_for(model)==HY3 else "glm"

def model_config(model):
    try:
        with open(os.path.join(model, "config.json")) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
