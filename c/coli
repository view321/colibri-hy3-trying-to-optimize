def is_hy3_repo(repo):
    if os.path.isdir(repo):
        return model_config(repo).get("model_type") == "hy_v3"
    r = repo.lower()
    return "hy3" in r or repo.startswith("tencent/Hy")

def engine_argv(model, cap):
    """Hy3 int4 containers need explicit ebits/dbits; GLM auto-detects from shard layout."""
    return [str(cap), "4", "8"] if engine_for(model) == HY3 else [str(cap)]
